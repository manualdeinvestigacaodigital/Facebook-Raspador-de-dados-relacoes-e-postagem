{
  "manifest_version": 3,
  "name": "Raspador de dados de relações e postagens do Facebook",
  "version": "44.21.28",
  "description": "Base estável 44.21.27 congelada. Alteração isolada de apresentação do seletor de formatos e recuperação/hiperlink de vídeo no HTML exportado, sem mudanças no motor de relações, comentários, reações, mídias de foto, navegação ou scroll.",
  "minimum_chrome_version": "114",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://static.xx.fbcdn.net/*",
    "https://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Raspador de dados de relações e postagens do Facebook"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": [
        "main_world_hook.js",
        "post_reaction_main_hook.js",
        "post_comment_main_hook.js",
        "reel_evidence_main_hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": [
        "unified_preflight.js",
        "content.js",
        "exact_relation_collector_442127.js",
        "post_reaction_bridge.js",
        "post_comment_bridge.js",
        "reel_evidence_bridge.js",
        "post_scraper_module.js",
        "unified_controller.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "version_name": "44.21.28 — base 44.21.27 congelada; seletor visível e vídeo disponível no HTML quando a URL for observada"
}
